# BeamPayRouter — BSC MAINNET (chainId 56)
# Copy to .env.bsc (gitignored), fill real values, then: source .env.bsc

# Deployer — prefer hardware wallet; never commit; rotate if hot key
PRIVATE_KEY=

# Etherscan V2 unified key (covers chain 56 + 1 + 97)
ETHERSCAN_API_KEY=

# Paid/reliable BSC RPC — do NOT use public dataseed for broadcast
BSC_RPC_URL=

# Governance multisig — MUST be multisig, NOT deployer EOA (immutable, invariant #3)
GOVERNANCE=

# Whitelist: NATIVE sentinel (BNB) , USDT (18 dec) , USDC (18 dec) — confirm addrs before deploy
INITIAL_TOKENS=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE,0x55d398326f99059fF775485246999027B3197955,0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# Fee recipients (comma-separated, 1..20)
INITIAL_RECIPIENTS=

# Protocol fee bps — MUST be <= 10 (0.1%)
INITIAL_FEE_RATE=10

# CreateX CREATE3 vanity salt (SAME value on BSC + ETH → identical address on all chains).
# Layout: deployer(20B) ++ 0x00 (redeploy-protect OFF) ++ entropy(11B). Mine via script/MineSalt.s.sol.
# Address is independent of chain/nonce/bytecode/constructor-args.
SALT=
