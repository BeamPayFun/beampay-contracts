# Deployer
PRIVATE_KEY=

# Explorer API V2
ETHERSCAN_API_KEY=

# RPC endpoints
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
ETH_RPC_URL=

# Deploy config — BeamRouter constructor inputs
# Governance multisig (will own fee parameters, token whitelist, recipients)
GOVERNANCE=

# Initial whitelist tokens (comma-separated, e.g. USDT,USDC addresses on target chain)
INITIAL_TOKENS=

# Initial fee recipients (comma-separated, 1..20 addresses)
INITIAL_RECIPIENTS=

# Initial protocol fee rate in basis points, MUST be <= 10 (0.1%)
INITIAL_FEE_RATE=10
