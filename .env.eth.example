# BeamPayRouter — ETHEREUM MAINNET (chainId 1)
# Copy to .env.eth (gitignored), fill real values, then: source .env.eth

# Deployer — prefer hardware wallet; never commit; rotate if hot key
PRIVATE_KEY=

# Etherscan V2 unified key (covers chain 1 + 56 + 97)
ETHERSCAN_API_KEY=

# Ethereum RPC — Alchemy/Infura
ETH_RPC_URL=

# Governance multisig — MUST be multisig, NOT deployer EOA (immutable, invariant #3)
GOVERNANCE=

# Whitelist: NATIVE sentinel (ETH) , USDT (6 dec) , USDC (6 dec) — confirm addrs before deploy
INITIAL_TOKENS=0xEeeeeEeeeEeEeeEeEeEeeEEEeeeeEeeeeeeeEEeE,0xdAC17F958D2ee523a2206206994597C13D831ec7,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Fee recipients (comma-separated, 1..20)
INITIAL_RECIPIENTS=

# Protocol fee bps — MUST be <= 10 (0.1%)
INITIAL_FEE_RATE=10

# CreateX CREATE3 vanity salt — MUST be the SAME value as in .env.bsc → identical address on all chains.
# Layout: deployer(20B) ++ 0x00 (redeploy-protect OFF) ++ entropy(11B). Mine via script/MineSalt.s.sol.
SALT=
